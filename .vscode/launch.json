{
    // File cấu hình launch.json cho VSCode - Chạy riêng server và worker
    "version": "0.2.0",
    "configurations": [
        {
            // Chạy server (API backend)
            "name": "Chạy Server (API Backend)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/api/cmd/server",
            "env": {
                "LOG_OUTPUT": "stdout",
                "AI_DECISION_LIVE_ORG_PERSIST": "true"
            },
            "args": []
        }
    ]
}